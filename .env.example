# =============================================================================
# Flipo environment template
# Copy to .env and fill in values. For production see docs/DEPLOY.md.
# =============================================================================

# --- API (Go) ----------------------------------------------------------------
API_PORT=8080
# development | production  (production refuses debug auth / chain-dev / weak JWT)
ENV=development
LOG_LEVEL=info
LOG_FILE=../../logs/api.log
# REQUIRED in production: long random secret (not the placeholder below)
JWT_SECRET=change-me-in-production

# Comma-separated allowed browser origins. Use * only for local/dev.
# Production example: https://your-domain.com,https://web.your-domain.com
CORS_ORIGINS=*

# --- Telegram bot ------------------------------------------------------------
BOT_TOKEN=your-telegram-bot-token
BOT_USERNAME=your_bot_username
# Public HTTPS URL of the Mini App (same origin as web in most setups)
TELEGRAM_WEBAPP_URL=https://your-domain.com
# Webhook endpoint must be HTTPS and reachable by Telegram
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=generate-a-long-random-secret
WEBAPP_SHORT_NAME=

# Channel subscription required to activate promo codes (@username, t.me link, or chat id)
PROMO_REQUIRED_CHANNEL=@your_channel
TELEGRAM_CHANNEL_URL=https://telegram.me/your_channel
TELEGRAM_SUPPORT_URL=https://telegram.me/your_support_chat
# Optional custom /start welcome text (supports \n). Empty = default.
TELEGRAM_WELCOME_TEXT=

# Admin panel + bot DM alerts (comma-separated Telegram user IDs). REQUIRED in production.
ADMIN_TELEGRAM_IDS=

# --- MTProto userbot (profile gift scanning) ---------------------------------
# https://my.telegram.org/apps — leave empty to disable gift scan
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+1234567890
TELEGRAM_SESSION_PATH=data/telegram/session.json

# --- Database / Redis --------------------------------------------------------
DATABASE_URL=postgres://flipo:flipo@localhost:5432/flipo?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# --- Games -------------------------------------------------------------------
ROULETTE_BETTING_SECONDS=20
ROULETTE_SPIN_SECONDS=12
ROULETTE_RESULT_PAUSE_SECONDS=0
ROULETTE_RESULT_DISPLAY_SECONDS=3
CRASH_TICK_MS=100
CRASH_BETTING_SECONDS=8
CRASH_GROWTH_PER_MS=0.00006
PLATFORM_FEE_BPS=500
BOOST_WAGER_THRESHOLD_NANOTON=5000000000
BOOST_REFERRAL_THRESHOLD=10

# --- TON deposits / withdrawals ----------------------------------------------
# MUST be false in production (fake deposits otherwise)
TON_CHAIN_DEV_MODE=false
TON_DEPOSIT_ADDRESS=
TON_API_BASE_URL=https://toncenter.com/api/v2
TON_API_KEY=
TON_LITE_CONFIG_URL=https://ton-blockchain.github.io/global.config.json
TON_HOT_WALLET_MNEMONIC=
TON_HOT_WALLET_VERSION=V5R1
TON_MIN_DEPOSIT_NANOTON=100000000
TON_MIN_WITHDRAW_NANOTON=100000000
TON_WITHDRAW_FEE_NANOTON=50000000
TON_DEPOSIT_TTL_MINUTES=30
# Excess balance from hot wallet sweeps here
TON_COLD_WALLET_ADDRESS=

# --- Social-sim bot assets (optional) ----------------------------------------
BOTS_DATA_DIR=assets/bots
BOTS_ASSETS_BASE_URL=/static/bots
# On-disk cache for proxied Fragment gift images (served at /static/gifts/*)
GIFTS_CACHE_DIR=data/gifts

# MRKT marketplace API token (from tgmrkt.io DevTools → Authorization header)
MRKT_API_TOKEN=

# GiftAsset aggregated gift prices (https://giftasset.gifts/docs) — non-black model floors
GIFTASSET_API_KEY=
GIFTASSET_BASE_URL=https://giftasset.gifts

# --- Next.js (web) -----------------------------------------------------------
WEB_PORT=3000
# Browser-facing API/WS. Prefer same-origin (empty or your public URL) + Next rewrites.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
# MUST be false in production (bypass Telegram login)
NEXT_PUBLIC_DEBUG_AUTH=false
NEXT_PUBLIC_BOT_NAME=Flipo Game Bot
NEXT_PUBLIC_GIFT_TRANSFER_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_PROMO_REQUIRED_CHANNEL=@your_channel
# Server-side rewrite target inside Docker/K8s (not exposed to browser)
API_UPSTREAM=http://127.0.0.1:8080

# --- Local debug only (NEVER enable in production) ---------------------------
DEBUG_AUTH_ENABLED=false
DEBUG_TELEGRAM_ID=999000001
DEBUG_USERNAME=debug_user
DEBUG_INITIAL_BALANCE_NANOTON=10000000000
